[Unit]
Description=AutoRip DVD - Plugin OpenMediaVault 7
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /srv/autorip/autorip_daemon.py --device /dev/sr0
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=autorip
User=root
Group=root
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
